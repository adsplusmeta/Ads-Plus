# Backups de base de datos
database/backups/*.gz
database/backups/*.enc

# Build del frontend
frontend/build/
frontend/dist/

# Cobertura de tests
coverage/

# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp

# Prometheus y Grafana data
monitoring/grafana/data/
monitoring/prometheus/data/

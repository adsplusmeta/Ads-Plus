# NUNCA commitear .env — solo este .env.example va al repositorio

NODE_ENV=production
PORT=5000

# Base de datos
DATABASE_URL=mongodb://localhost:27017/dbname
# En producción incluir autenticación y SSL:
# DATABASE_URL=mongodb://user:password@host:27017/dbname?ssl=true&authSource=admin

# JWT — mínimo 32 caracteres aleatorios
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_USE_openssl_rand_-hex_32
JWT_EXPIRES_IN=15m

# Cifrado — exactamente 32 bytes en hex = 64 caracteres
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_THIS_64_HEX_CHAR_STRING

# CORS — dominios separados por coma
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Sesión — mínimo 32 caracteres
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# MongoDB (para docker-compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MONGO_DATABASE=myapp

# Email (para reset de contraseña)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# 2FA
TWO_FACTOR_APP_NAME=MiApp

# Logging
LOG_LEVEL=info

# Backup
BACKUP_ENCRYPTION_KEY=CHANGE_THIS_BACKUP_KEY
